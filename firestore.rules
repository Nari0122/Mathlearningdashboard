rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // 도움 함수 (Reference Style)
    // =========================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // 현재 사용자의 문서를 가져옵니다
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // 역할 확인 (Prisma Schema 기준: role은 'admin' 또는 'student')
    function isAdmin() {
      return isAuthenticated() && getUserDoc().data.role == 'admin';
    }

    // 경로의 마지막 부분을 추출합니다 (ID 추출용)
    function getLastSegment(path) {
      let segments = path.split('/');
      return segments[segments.size() - 1];
    }

    // 유연한 소유자 확인 (userId가 경로든 문자열이든 처리)
    function isOwner(userId) {
      let target = getLastSegment(string(userId));
      let me = getLastSegment(string(request.auth.uid));
      return isAuthenticated() && target == me;
    }

    // 리소스(이미 저장된 데이터)의 주인이 나인지 확인
    function isResourceOwner() {
      return isOwner(resource.data.userId);
    }

    // 요청(새로 저장할 데이터)의 주인이 나인지 확인
    function isRequestOwner() {
      return isOwner(request.resource.data.userId);
    }

    // =========================================================
    // 1. 회원 정보 (Users & Profiles)
    // - 관리자: 모든 권한
    // - 학생: 본인 정보 읽기만 가능 (수정/탈퇴 불가)
    // =========================================================
    match /users/{userId} {
      allow create: if true; // 회원가입은 누구나 가능 (추후 관리자 승인제라면 isAdmin으로 변경 고려)
      
      // 읽기: 본인 또는 관리자
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // 수정/삭제: 오직 관리자만 (학생 스스로 정보 수정/탈퇴 불가)
      allow update, delete: if isAdmin();
    }

    match /studentProfiles/{profileId} {
      // 생성/수정/삭제: 관리자만
      allow create, update, delete: if isAdmin();
      
      // 읽기: 본인 또는 관리자
      allow read: if isAuthenticated() && (isResourceOwner() || isAdmin());
    }

    match /students/{studentId} {
      // 생성/수정/삭제: 관리자만
      allow create, update, delete: if isAdmin();
      
      // 읽기: 본인 또는 관리자
      allow read: if isAuthenticated() && (isOwner(studentId) || isAdmin());

      // 하위 컬렉션에 대한 기본 권한 (관리자만 쓰기 가능)
      // 필요에 따라 exams 등은 학생 권한을 따로 줄 수 있으나, 
      // 현재는 안전하게 관리자 위주로 설정
      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && (isOwner(studentId) || isAdmin());
        allow create, update, delete: if isAdmin();
      }
    }

    // =========================================================
    // 2. 학습 콘텐츠 (Units, Homeworks)
    // - 학생이 '난이도 선택'이나 '숙제 제출'을 해야 하므로 UPDATE 허용
    // =========================================================
    match /units/{unitId} {
      // 생성/삭제: 관리자만 (커리큘럼 관리)
      allow create, delete: if isAdmin();
      
      // 읽기: 본인 또는 관리자
      allow read: if isAuthenticated() && (isResourceOwner() || isAdmin());
      
      // 수정: 본인(난이도 선택 등) 또는 관리자
      allow update: if isAuthenticated() && (isResourceOwner() || isAdmin());
    }

    match /homeworks/{homeworkId} {
      // 생성/삭제: 관리자만 (숙제 내주기)
      allow create, delete: if isAdmin();
      
      // 읽기: 본인 또는 관리자
      allow read: if isAuthenticated() && (isResourceOwner() || isAdmin());
      
      // 수정: 본인(숙제 제출 상태 변경) 또는 관리자
      allow update: if isAuthenticated() && (isResourceOwner() || isAdmin());
    }

    // =========================================================
    // 3. 시험 및 시간표 (Exams, Schedules)
    // - 시간표: 읽기 전용
    // - 시험: 학생이 자유롭게 생성/수정/삭제 가능
    // =========================================================
    match /exams/{examId} {
      // 학생이 자신의 시험 점수를 자유롭게 기록하고 관리
      allow create: if isAuthenticated() && (isRequestOwner() || isAdmin());
      allow read, update, delete: if isAuthenticated() && (isResourceOwner() || isAdmin());
    }

    match /schedules/{scheduleId} {
      allow create, update, delete: if isAdmin();
      allow read: if isAuthenticated() && (isResourceOwner() || isAdmin());
    }

    // =========================================================
    // 4. 학습 기록 (LearningRecords)
    // - 학생은 보기만 함 (선생님이 기록 관리)
    // =========================================================
    match /learningRecords/{recordId} {
      // 관리자만 작성/수정/삭제
      allow create, update, delete: if isAdmin();
      
      // 읽기: 본인 또는 관리자
      allow read: if isAuthenticated() && (isResourceOwner() || isAdmin());
    }

    // =========================================================
    // 5. 오답노트 (IncorrectNotes) - 자기주도 학습
    // - 학생이 자유롭게 생성/수정/삭제 가능
    // =========================================================
    match /incorrectNotes/{noteId} {
      // 본인 데이터 생성/수정/삭제/읽기 모두 허용
      allow create: if isAuthenticated() && (isRequestOwner() || isAdmin());
      allow read, update, delete: if isAuthenticated() && (isResourceOwner() || isAdmin());

      // 오답노트 첨부파일
      match /attachments/{attachmentId} {
        allow create: if isAuthenticated();
        allow read: if isAuthenticated();
        // 본인 오답노트의 파일이면 수정/삭제 가능해야 하지만, 
        // 복잡도를 줄이기 위해 일단 읽기/생성은 허용, 삭제는 관리자만(또는 추후 정책 결정)
        // 오답노트 삭제 시 같이 지워지는 로직이라면 부모 권한을 따름.
        allow update, delete: if isAdmin(); // (일단 안전하게 관리자만)
      }
    }

    // =========================================================
    // 6. 시스템 설정 및 기타
    // =========================================================
    match /systemSettings/{settingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // 첨부파일 (최상위)
    match /attachments/{attachmentId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // =========================================================
    // 기본 차단 규칙 (안전장치)
    // =========================================================
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
